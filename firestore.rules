rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: inquiries
    // Document ID: auto-generated
    // Fields:
    //   - parentName: string (required, 1-100 chars)
    //   - childAge: string (optional, 0-50 chars)
    //   - email: string (required, valid email format)
    //   - message: string (required, 1-2000 chars)
    //   - type: string (required, enum: ['enrollment', 'training'])
    //   - status: string (required, enum: ['new', 'read', 'archived'])
    //   - createdAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required, valid email)
    //   - role: string (required, enum: ['admin', 'user'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "muselec52@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Inquiries & Applications
    match /{collection}/{docId} {
      allow create: if collection in ['inquiries', 'applications'];
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAdmin();
    }
  }
}
